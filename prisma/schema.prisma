generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Rider {
  id              String   @id @default(cuid())
  phone           String   @unique
  name            String
  email           String?
  vehicleType     String   @default("bicycle") // bicycle, scooter, motorcycle, car
  rating          Float    @default(4.5)
  totalDeliveries Int      @default(0)
  totalEarnings   Int      @default(0) // in paisa (1/100 INR)
  tier            String   @default("bronze") // bronze, silver, gold, platinum
  isOnline        Boolean  @default(false)
  mpgcsScore      Int      @default(700) // Multi-Platform Gig Comparison Score
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  platforms       RiderPlatform[]
  deliveries      Delivery[]
  earnings        Earning[]
  shifts          Shift[]
  notifications   Notification[]
  autoAcceptRules AutoAcceptRule[]
  settings        RiderSettings?
  referralsMade   Referral[]      @relation("ReferralsMade")
  referralsReceived Referral[]    @relation("ReferralsReceived")
  deviceFingerprints DeviceFingerprint[]
  kycVerification KYCVerification?
}

model RiderPlatform {
  id             String   @id @default(cuid())
  riderId        String
  platformId     String   // swiggy, zomato, ubereats, doordash, etc.
  isOnline       Boolean  @default(false)
  isRegistered   Boolean  @default(true)
  todayEarnings  Int      @default(0) // in paisa
  todayOrders    Int      @default(0)
  rating         Float    @default(4.5)
  acceptanceRate Int      @default(85) // percentage
  completionRate Int      @default(95) // percentage
  autoAccept     Boolean  @default(false)
  minPayout      Int      @default(3000) // in paisa (₹30)
  maxDistance    Float    @default(8.0) // in km
  shiftStart     String?  // "09:00"
  shiftEnd       String?  // "21:00"
  connectedAt    DateTime @default(now())

  rider          Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, platformId])
}

model Delivery {
  id              String    @id @default(cuid())
  riderId         String
  platform        String    // swiggy, zomato, etc.
  status          String    @default("pending") // pending, accepted, picked_up, completed, cancelled
  customerName    String
  restaurantName  String
  pickupAddress   String
  dropoffAddress  String
  earnings        Int       @default(0) // in paisa
  tip             Int       @default(0) // in paisa
  distance        Float     @default(0.0) // in km
  duration        Int       @default(0) // in minutes
  orderValue      Int       @default(0) // in paisa
  platformFee     Int       @default(0) // in paisa
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  rider           Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)
  earningsRecords Earning[]
}

model Earning {
  id          String   @id @default(cuid())
  riderId     String
  deliveryId  String?  // optional — bonuses/incentives may not be linked to a delivery
  amount      Int      // in paisa
  source      String   // delivery, tip, bonus, incentive, referral
  platform    String   // swiggy, zomato, etc.
  description String?
  createdAt   DateTime @default(now())

  rider       Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
  delivery    Delivery? @relation(fields: [deliveryId], references: [id], onDelete: SetNull)
}

model Shift {
  id         String   @id @default(cuid())
  riderId    String
  date       String   // "2025-01-15" or "monday", "tuesday", etc.
  startTime  String   // "09:00"
  endTime    String   // "21:00"
  isActive   Boolean  @default(false)
  platformId String?  // optional — null means all platforms

  rider      Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  riderId   String
  type      String   // order_accepted, order_completed, earnings_milestone, platform_update, tier_upgrade, tip_received, stack_order
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  rider     Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

model AutoAcceptRule {
  id                 String   @id @default(cuid())
  riderId            String
  platformId         String   // which platform this rule applies to
  enabled            Boolean  @default(false)
  minPayout          Int      @default(3000) // in paisa (₹30)
  maxDistance        Float    @default(8.0) // in km
  peakBoost          Int      @default(0) // percentage boost during peak hours
  smartStack         Boolean  @default(false)
  preferredPlatforms String   @default("") // comma-separated platform ids
  updatedAt          DateTime @updatedAt

  rider              Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([riderId, platformId])
}

model RiderSettings {
  id                   String   @id @default(cuid())
  riderId              String   @unique
  notifications        String   @default("{}") // JSON string
  theme                String   @default("light") // light, dark, system
  language             String   @default("en")
  currency             String   @default("INR")
  soundEnabled         Boolean  @default(true)
  autoOnline           Boolean  @default(false)
  maxDailyKm           Int      @default(100)
  breakReminder        Boolean  @default(true)
  breakIntervalMinutes Int      @default(120)
  dataExportFormat     String   @default("csv") // csv, json, pdf
  privacyMode          Boolean  @default(false)
  updatedAt            DateTime @updatedAt

  rider                Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)
}

// ==================== REFERRAL & FRAUD PREVENTION ====================

model Referral {
  id                    String   @id @default(cuid())
  referrerId            String   // Rider who shared the code
  refereeId             String   // Rider who used the code
  referralCode          String   // Code used by referee
  status                String   @default("pending") // pending, qualified, on_hold, paid, rejected, fraud_detected
  referrerBonusAmount   Int      @default(20000) // in paisa (₹200)
  refereeBonusAmount    Int      @default(10000) // in paisa (₹100)
  refereeDeliveriesAtQualify Int  @default(0) // deliveries count when qualified
  qualifiedAt           DateTime? // When referee completed 10 deliveries
  holdEndDate           DateTime? // qualifiedAt + 7 days
  paidAt                DateTime? // When bonus was actually paid
  fraudFlags            String   @default("[]") // JSON array of fraud flag types
  riskScore             Int      @default(0) // 0-100
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  referrer              Rider    @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referee               Rider    @relation("ReferralsReceived", fields: [refereeId], references: [id], onDelete: Cascade)
}

model DeviceFingerprint {
  id              String   @id @default(cuid())
  riderId         String
  deviceId        String   @unique // Hashed fingerprint - one device per account
  userAgent       String   @default("")
  screenResolution String  @default("")
  timezone        String   @default("")
  language        String   @default("")
  platform        String   @default("")
  canvasHash      String   @default("")
  webglHash       String   @default("")
  audioHash       String   @default("")
  ipAddress       String   @default("")
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())

  rider           Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([ipAddress])
}

model KYCVerification {
  id              String    @id @default(cuid())
  riderId         String    @unique
  aadhaarNumber   String?   // Last 4 digits only stored
  aadhaarVerified Boolean   @default(false)
  aadhaarVerifiedAt DateTime?
  panNumber       String?   // Full PAN stored encrypted in production
  panVerified     Boolean   @default(false)
  panVerifiedAt   DateTime?
  selfieVerified  Boolean   @default(false)
  selfieVerifiedAt DateTime?
  livenessPassed  Boolean   @default(false) // Did the selfie liveness check pass
  bankAccount     String?   // Masked bank account number
  bankIfsc        String?
  bankVerified    Boolean   @default(false)
  bankVerifiedAt  DateTime?
  bankName        String?   // Bank name from IFSC lookup
  upiId           String?
  kycLevel        Int       @default(0) // 0=none, 1=basic(Aadhaar), 2=full(Aadhaar+PAN+Bank+Selfie)
  overallStatus   String    @default("unverified") // unverified, pending, basic_verified, fully_verified, rejected
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rider           Rider     @relation(fields: [riderId], references: [id], onDelete: Cascade)
}
